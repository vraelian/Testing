  "function_index": {
    "GameState.startNewGame": {
      "asset_id": "F009",
      "description": "Initializes the game state for a new game, setting all player and market data to its default starting values.",
      "params": [
        {
           "name": "playerName",
          "type": "string"
        }
      ],
      "returns": {
        "type": "void"
      },
      "mutates_state": [
        "day",
        "lastInterestChargeDay",
        "lastMarketUpdateDay",
        "currentLocationId",
        "activeNav",
        "activeScreen",
        "player",
        "market",
        "intel",
        "tutorials",
        "introSequenceActive"
      ],
      "calls": [
        "GameState._getTierAvailability",
        "GameState._calculateGalacticAverages",
        "GameState._seedInitialMarketPrices",
        "GameState.setState"
      ]
    },
    "GameState.procedurallyGenerateTravelData": {
      "asset_id": "F009",
      "description": "Calculates the travel time and fuel cost between all market locations based on their index in the MARKETS array, creating a static data object for travel.",
      "params": [
        {
          "name": "markets",
          "type": "array"
        }
      ],
      "returns": {
         "type": "object"
      },
      "mutates_state": [],
      "calls": []
    },
    "GameState.setState": {
      "asset_id": "F009",
      "description": "Merges a partial state object into the main game state and notifies all subscribers of the change.",
      "params": [
        {
          "name": "partialState",
          "type": "object"
        }
      ],
      "returns": {
        "type": "void"
      },
      "mutates_state": [
        "any"
      ],
      "calls": [
        "GameState._notify"
      ]
    },
    "GameState.getState": {
      "asset_id": "F009",
      "description": "Returns a deep copy of the current game state to ensure state immutability for consumers.",
      "params": [],
      "returns": {
        "type": "state_schema"
      },
      "mutates_state": [],
      "calls": []
    },
    "GameState._calculateGalacticAverages": {
      "asset_id": "F009",
      "description": "Calculates the baseline average price for each commodity based on its defined basePriceRange.",
      "params": [],
      "returns": {
        "type": "void"
      },
      "mutates_state": [
        "market.galacticAverages"
      ],
      "calls": []
    },
    "GameState._seedInitialMarketPrices": {
      "asset_id": "F009",
      "description": "Sets the initial market price for every commodity at every location, applying randomness and location-specific modifiers.",
      "params": [],
      "returns": {
        "type": "void"
      },
      "mutates_state": [
        "market.prices"
      ],
      "calls": []
    },
    "MarketService.evolveMarketPrices": {
      "asset_id": "F010",
      "description": "Updates all commodity prices for a single day's tick based on volatility and mean reversion logic.",
      "params": [],
      "returns": {
           "type": "void"
      },
      "mutates_state": [
        "market.prices",
        "market.priceHistory"
      ],
      "calls": [
        "MarketService._recordPriceHistory"
      ]
    },
    "MarketService.replenishMarketInventory": {
      "asset_id": "F010",
      "description": "Updates the available quantity of all commodities at all markets, simulating replenishment over time.",
      "params": [],
      "returns": {
        "type": "void"
      },
      "mutates_state": [
        "market.inventory"
      ],
      "calls": [
        "MarketService._getTierAvailability"
      ]
    },
    "MarketService._getTierAvailability": {
      "asset_id": "F010",
      "description": "Returns the min and max potential stock for a commodity based on its tier.",
      "params": [
        {
          "name": "tier",
          "type": "integer"
        }
      ],
      "returns": {
        "type": "object"
      },
      "mutates_state": [],
      "calls": []
    },
    "MarketService._recordPriceHistory": {
      "asset_id": "F010",
      "description": "Adds the current day's price for each commodity to its historical data log, trimming old entries.",
      "params": [],
      "returns": {
        "type": "void"
      },
      "mutates_state": [
        "market.priceHistory"
      ],
      "calls": []
    },
    "SimulationService.startIntroSequence": {
        "asset_id": "F011",
        "description": "Kicks off the V1 interactive introduction sequence by setting the initial step and showing the first modal.",
        "params": [],
        "returns": { "type": "void" },
        "mutates_state": ["player.introStep"],
        "calls": ["SimulationService._showNextIntroModal"]
    },
    "SimulationService._showNextIntroModal": {
        "asset_id": "F011",
        "description": "Reads the current intro step from the game state and displays the corresponding modal from the INTRO_SEQUENCE_V1 data.",
        "params": [],
        "returns": { "type": "void" },
        "mutates_state": [],
        "calls": ["UIManager.queueModal", "SimulationService._setupIntroModal", "SimulationService._endIntroSequence"]
    },
    "SimulationService._setupIntroModal": {
        "asset_id": "F011",
        "description": "Performs custom setup for special intro modals, like the charter and signature modals, which have interactive elements.",
        "params": [
            { "name": "modal", "type": "HTMLElement" },
            { "name": "step", "type": "object" },
            { "name": "closeHandler", "type": "function" }
        ],
        "returns": { "type": "void" },
        "mutates_state": [],
        "calls": []
    },
    "SimulationService.handleIntroClick": {
        "asset_id": "F011",
        "description": "Central handler for all click events during the intro sequence. It advances lore modals, processes the signature, and triggers the transition to the main game.",
        "params": [{"name": "e", "type": "Event"}],
        "returns": { "type": "void" },
        "mutates_state": ["player.introStep", "player.name", "player.credits", "player.debt", "player.loanStartDate", "player.weeklyInterestAmount", "player.ownedShipIds", "player.shipStates", "player.inventories", "player.activeShipId"],
        "calls": ["SimulationService._showNextIntroModal", "UIManager.queueModal", "SimulationService.setScreen", "TutorialService.checkState"]
    },
    "SimulationService._continueIntroSequence": {
        "asset_id": "F011",
        "description": "Manages the guided flow of the intro after a tutorial part is completed, e.g., moving from Hangar tutorial to Finance tutorial.",
        "params": [{"name": "completedBatchId", "type": "string"}],
        "returns": { "type": "void" },
        "mutates_state": [],
        "calls": ["SimulationService.setScreen", "TutorialService.checkState", "SimulationService._endIntroSequence"]
    },
    "SimulationService._endIntroSequence": {
        "asset_id": "F011",
        "description": "Finalizes the introduction, sets the introSequenceActive flag to false, unlocks the UI, and shows the final motivational modal.",
        "params": [],
        "returns": { "type": "void" },
        "mutates_state": ["introSequenceActive"],
        "calls": ["UIManager.queueModal", "UIManager.render", "SimulationService.setScreen"]
    },
    "SimulationService.setScreen": {
       "asset_id": "F011",
      "description": "Sets the active navigation tab and screen, then triggers a full UI re-render and checks for tutorial state changes.",
      "params": [
        {
          "name": "navId",
          "type": "NavId"
        },
        {
          "name": "screenId",
           "type": "ScreenId"
        }
      ],
      "returns": {
        "type": "void"
      },
      "mutates_state": [
        "activeNav",
        "activeScreen",
        "lastActiveScreen"
      ],
      "calls": [
        "UIManager.render",
        "TutorialService.checkState",
         "GameState.setState"
      ]
    },
    "SimulationService.travelTo": {
      "asset_id": "F011",
      "description": "Validates if travel to a destination is possible (checks fuel) and then either initiates it or triggers a random event first.",
      "params": [
        {
          "name": "locationId",
          "type": "LocationId"
         }
      ],
      "returns": {
        "type": "void"
      },
      "mutates_state": [],
      "calls": [
        "SimulationService._getActiveShip",
        "SimulationService._checkForRandomEvent",
        "SimulationService.initiateTravel",
