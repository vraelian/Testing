      ]
    },
    "SimulationService.initiateTravel": {
      "asset_id": "F011",
       "description": "Executes the core travel logic after validation, applying fuel costs, hull damage, advancing time, and showing the travel animation.",
      "params": [
        {
          "name": "locationId",
          "type": "LocationId"
        },
        {
          "name": "eventMods",
          "type": "object",
           "optional": true
        }
      ],
      "returns": {
        "type": "void"
      },
      "mutates_state": [
        "player.shipStates",
        "currentLocationId",
        "pendingTravel"
