        "SimulationService._handleShipDestruction",
        "GameState.setState",
        "UIManager.showTravelAnimation"
      ]
    },
    "SimulationService.resumeTravel": {
      "asset_id": "F011",
      "description": "Continues a pending travel action after an interruption, such as a random event.",
