{
  "_meta": {
    "purpose": "Comprehensive routing directory, AI constraint ledger, and relational map for the Virtual Workbench methodology.",
    "architecture_pattern": "Strict Unidirectional Data Flow: Input -> Logic (Service) -> State (Mutation) -> Output (Render)",
    "environment": "MacBook Air, VSCode Live Server (Web), Xcode Simulator (iOS WKWebView)"
  },
  "ai_directives": {
    "workflow": [
      "Operate strictly using the Virtual Workbench methodology. Identify virtual blocks, perform surgical modifications, and leave stable blocks untouched.",
      "Adopt a strict Append/Merge strategy for all file updates. Never truncate code for convenience.",
      "Output the final result as a single, complete, and immediately executable file.",
      "Maintain strict phase-isolation. Consolidate changes into a single file update per phase.",
      "Never use video game analogies to explain non-gaming technical concepts."
    ],
    "game_logic_and_lore": [
      "Character Name spelling is strictly 'Kiern' (never 'Keirn').",
      "Mission 21 is a 'delivery' mission (requires objective location to trigger modal immediately).",
      "Mission 32 requires 'Badge II' ship upgrades to be awarded strictly AFTER the white screen transition sequence, not before.",
      "Mission 34 requires a Rank III upgrade.",
      "Commodities (trade goods) are strictly distinct from Consumables (usable items). Do not cross-reference them.",
      "Orbital Trading UI Abbreviations: pop = popup, toast = toast window modal, fbt = floating battle text, TT = tutorial toast, intro = entire introduction sequence."
    ],
    "design_and_style": [
      "Aesthetic: Gritty industrial sci-fi.",
      "Never implement hover-over design or features (iOS touch screen primary).",
      "CSS variable updates in .css files must be perfectly synchronized with initial values in this.state and this.defaults within js/services/DebugService.js."
    ],
    "relational_bindings": {
